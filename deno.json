{
  "name": "bootc-buddy",
  "version": "0.1.0",
  "exports": "./src/main.tsx",
  "nodeModulesDir": "auto",
  "imports": {
    "@gtkx/cli": "npm:@gtkx/cli@0.21.0",
    "@gtkx/ffi": "npm:@gtkx/ffi@0.21.0",
    "@gtkx/native": "npm:@gtkx/native@0.21.0",
    "@gtkx/native-linux-x64": "npm:@gtkx/native-linux-x64@0.21.0",
    "@gtkx/react": "npm:@gtkx/react@0.21.0",
    "@types/react": "npm:@types/react@19.2.17",
    "react": "npm:react@19.2.7",
    "try": "npm:try@1.0.3",
    "vite": "npm:vite@8.0.16"
  },
  "compilerOptions": {
    "jsx": "react-jsx"
  },
  "tasks": {
    "dev": "deno run -A scripts/dev.ts",
    "compile": "deno run -A @gtkx/cli build src/main.tsx && deno compile -P --no-check --node-modules-dir=none --output=bin/bootc-buddy dist/bundle.js",
    "build": "deno run -A scripts/build.ts",
    "fmt": "deno fmt",
    "lint": "deno lint && deno task lint:docs",
    "lint:docs": "deno doc --lint --quiet src/**/*.ts src/**/*.tsx",
    "check": "deno check src/**/*.ts src/**/*.tsx"
  },
  "compile": {
    "permissions": { "all": true },
    "include": ["dist"]
  },
  "fmt": {
    "include": [
      "src/",
      "scripts/",
      "vite.config.ts"
    ],
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve"
  },
  "lint": {
    "include": [
      "src/",
      "scripts/",
      "vite.config.ts"
    ],
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  }
}
