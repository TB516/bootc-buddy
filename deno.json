{
  "nodeModulesDir": "auto",
  "workspace": [
    "./packages/app",
    "./packages/daemon"
  ],
  "tasks": {
    "dev": "deno task dev:app & deno task dev:daemon",
    "dev:app": "deno task --cwd packages/app dev",
    "dev:daemon": "deno task --cwd packages/daemon dev",
    "fmt": "deno task fmt:app && deno task fmt:daemon",
    "fmt:app": "deno task --cwd packages/app fmt",
    "fmt:daemon": "deno task --cwd packages/daemon fmt",
    "lint": "deno task lint:app && deno task lint:daemon",
    "lint:app": "deno task --cwd packages/app lint",
    "lint:daemon": "deno task --cwd packages/daemon lint",
    "check": "deno task check:app && deno task check:daemon",
    "check:app": "deno task --cwd packages/app check",
    "check:daemon": "deno task --cwd packages/daemon check"
  },
  "fmt": {
    "include": [
      "packages/"
    ],
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve"
  },
  "lint": {
    "include": [
      "packages/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  }
}
