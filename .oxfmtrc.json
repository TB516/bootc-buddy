{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "bin/**",
    "dist/**",
    "node_modules/**",
    ".flatpak-build/**",
    ".flatpak-build-release/**",
    ".flatpak-builder*/**"
  ],
  "insertFinalNewline": true,
  "jsdoc": {
    "commentLineStrategy": "keep",
    "lineWrappingStyle": "balance"
  },
  "printWidth": 100,
  "proseWrap": "preserve",
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "useTabs": false
}
