{
  "name": "@bootc-buddy/app",
  "version": "0.1.0",
  "exports": "./src/index.tsx",
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@2.0.2",
    "@gtkx/cli": "npm:@gtkx/cli@0.21.0",
    "@gtkx/ffi": "npm:@gtkx/ffi@0.21.0",
    "@gtkx/native": "npm:@gtkx/native@0.21.0",
    "@gtkx/native-linux-x64": "npm:@gtkx/native-linux-x64@0.21.0",
    "@gtkx/react": "npm:@gtkx/react@0.21.0",
    "react": "npm:react@19.2.7",
    "vite": "npm:vite@8.0.16"
  },
  "compilerOptions": {
    "jsx": "react",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "React.Fragment"
  },
  "tasks": {
    "dev": "deno run -A @gtkx/cli dev src/dev.tsx",
    "start": "deno task bundle && deno run -A dist/bundle.js",
    "bundle": "deno run -A scripts/build.ts --bundle-only",
    "build": "deno run -A scripts/build.ts",
    "check": "deno check src/index.tsx src/dev.tsx src/app.tsx scripts/build.ts"
  }
}
