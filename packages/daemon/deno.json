{
  "name": "@bootc-buddy/daemon",
  "version": "0.1.0",
  "exports": {
    ".": "./src/app.ts",
    "./socket": "./src/socket.ts"
  },
  "tasks": {
    "dev": "deno run --allow-env --allow-read --allow-write --watch src/main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint && deno task lint:docs",
    "lint:docs": "deno doc --lint --quiet src/**/*.ts",
    "check": "deno check src/**/*.ts"
  },
  "imports": {
    "elysia": "npm:elysia@^1.4.28"
  }
}
