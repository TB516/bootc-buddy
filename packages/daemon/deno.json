{
  "name": "@bootc-buddy/daemon",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run --watch src/main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint && deno task lint:docs",
    "lint:docs": "deno doc --lint src/**/*.ts",
    "check": "deno check src/**/*.ts"
  }
}
